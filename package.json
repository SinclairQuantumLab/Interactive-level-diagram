{
  "name": "interactive-atomic-level-diagram",
  "productName": "Interactive Atomic Level Diagram",
  "version": "0.1.0",
  "description": "Local interactive atomic level diagram viewer and editor shell.",
  "author": "Joons",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win dir",
    "build:linux": "electron-builder --linux dir",
    "build:mac": "electron-builder --mac dir"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "katex": "^0.16.38"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.joons.interactiveatomicleveldiagram",
    "asar": false,
    "directories": {
      "output": "run"
    },
    "win": {
      "executableName": "run_Windows",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "files": [
      "index.html",
      "src/**/*",
      "diagrams/**/*",
      "node_modules/d3/**/*",
      "node_modules/katex/**/*",
      "package.json"
    ]
  }
}
